	str_version	= "1.0"
	str_date	= "17.2.2026"

	wid_diff 	= int_ui_wid - 480				! Differenz Breite zu Standard
	hit_diff 	= int_ui_hit - 266				! Differenz Höhe zu Standard

	UI_DIALOG str_objectName + " V" + str_version + ":" + str_date, int_ui_wid, int_ui_hit

