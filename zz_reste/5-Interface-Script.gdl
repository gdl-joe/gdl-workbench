! Script_UI
! --- UI-DESIGNER AUTO-CODE START ---
! --- UI-DESIGNER AUTO-CODE START ---


UI_DIALOG "GDL-UI-Studio", 444, 266

	int_ui_wid	= 444
	int_ui_hit	= 266
	nTabs     	= 6
	str_objectName	= "Project"
	str_version	= "1.0"
	str_date	= "17.2.2026"

	wid_diff 	= int_ui_wid - 480				! Differenz Breite zu Standard
	hit_diff 	= int_ui_hit - 266				! Differenz Höhe zu Standard

	UI_DIALOG str_objectName + " V" + str_version + ":" + str_date, int_ui_wid, int_ui_hit

	! Parameters for ArchiCAD version and Platform
	Dose = 0
	GDL = REQ("GDL_Version")
	sts = REQUEST("Name_of_program", "", TeX)
	IF STRSTR(TeX,".EXE") OR STRSTR(TeX,".exe") THEN Dose = 1

	! Seitendefinition
	UI_CURRENT_PAGE gs_ui_current_page

	dy_start = 30
	led = 25
	tx1 = 0
	drawBox = 1

! ---------------------------------------------------------------------- ! 
! ---------------------------------------------------------------------- ! 

TABID_ROOT = -1
DIM TAB_ID[], TAB_ID_SUB[][]

! Tab-IDs dynamisch generieren
_idxTab = 1
FOR i = 1 TO nTabs
    TAB_ID[i] = _idxTab
    _idxTab = _idxTab + 1
    IF nTabs_sub[i] > 1 THEN
        FOR j = 1 TO (nTabs_sub[i] - 1)
            TAB_ID_SUB[i][j] = _idxTab
            _idxTab = _idxTab + 1
        NEXT j
    ENDIF
NEXT i

! UI-Pages dynamisch erstellen
FOR i = 1 TO nTabs
    UI_PAGE TAB_ID[i], TABID_ROOT, TabTitles[i], TabPicture[i]
    GOSUB "UI_PAGE " + STR(i, 1, 0)
    IF nTabs_sub[i] > 1 THEN
        FOR j = 1 TO (nTabs_sub[i] - 1)
            UI_PAGE TAB_ID_SUB[i][j], TAB_ID[i], subTabTitles[i][j+1], subTabPicture[i][j+1]
            GOSUB "UI_PAGE " + STR(i, 1, 0) + "_" + STR(j, 1, 0)
        NEXT j
    ENDIF
NEXT i
! --- UI-DESIGNER AUTO-CODE START ---
