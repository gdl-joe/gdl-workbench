! ---------------------------- E N D ----------------------------------- !
! ---------------------------- E N D ----------------------------------- !

! ---------------------------------------------------------------------- ! 
! ---------------------------------------------------------------------- ! 
"UI_PAGE 1":

	GOSUB 99						! UI-DRAWABOX 
	GOSUB 100						! UI-Tabcontrol 
	dy = dy_start


RETURN 

! ---------------------------------------------------------------------- ! 
! ---------------------------------------------------------------------- ! 

! ---------------------------------------------------------------------- ! 
! ---------------------------------------------------------------------- ! 
"UI_PAGE 2":

	GOSUB 99						! UI-DRAWABOX 
	GOSUB 100						! UI-Tabcontrol 
	dy = dy_start


RETURN 

! ---------------------------------------------------------------------- ! 
! ---------------------------------------------------------------------- ! 

! ---------------------------------------------------------------------- ! 
! ---------------------------------------------------------------------- ! 
