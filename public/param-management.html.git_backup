
<!DOCTYPE html>
<html lang="de">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>GDL-UI-Studio - Parameterverwaltung</title>
	<link rel="stylesheet" href="style.css">
	<!-- FONT AWESOME für Icons -->
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>
<body>
	<div class="app-container">
		<!-- HEADER -->
		<header class="app-header">
			<div class="header-left">
				<span class="logo">GDL-UI-Studio</span>
				<span class="project-info" id="currentProjectName"></span>
				<span class="object-info" id="currentObjectName"></span>
			</div>
		
			<div class="header-right">
				<button class="header-btn" id="saveBtn" title="Alle Änderungen werden automatisch gespeichert">💾 Auto-Save aktiv</button>
				<span class="separator">|</span>
				<button class="header-btn primary" id="generateBtn">GDL-Skripte generieren</button>
				<button class="header-btn" id="downloadBtn">Download</button>
				<div class="lang-switcher">
					<select>
						<option value="de">Deutsch</option>
						<option value="en">English</option>
					</select>
				</div>
			</div>
		</header>


		<!-- MAIN NAVIGATION -->
		<nav class="main-nav">
			<a href="dashboard.html" class="nav-button">Projektverwaltung</a>
			<a href="object-selection.html" class="nav-button">Objektverwaltung</a>
			<a href="param-management.html" class="nav-button active">Parameterverwaltung</a>
			<a href="index.html" class="nav-button">UI Designer</a>
		</nav>

		<!-- MAIN CONTENT AREA - Parameterverwaltung -->
		<main class="app-main param-management-page">
			<aside class="left-panel">
				<h3>Aktionen</h3>
				<input type="file" id="xmlFileInput" accept=".xml" style="display: none;">
				<button class="action-btn import-xml" id="importXmlButton">XML Parameter Import</button>
				<button class="action-btn import-csv">CSV Produktdaten Import</button>
				<button class="action-btn">Parameter Export (XML)</button>
				<button class="action-btn add-param">Neuen Parameter hinzufügen</button>
				<button class="action-btn delete-param disabled">Ausgewählte löschen</button>
			</aside>

			<section class="central-panel-table">
				<h3>GDL-Parameterliste</h3>
				<div class="table-controls">
					<label for="filter-param">Suchen:</label>
					<input type="text" id="filter-param" placeholder="Parameter filtern...">
				</div>
				<div class="param-table-container">
					<table class="param-table">
						<thead>
							<tr>
								<th><input type="checkbox" class="select-all"></th>
								<th></th> <!-- Drag Handle -->
								<th>Typ <i class="fas fa-sort-up"></i></th>
								<th>Name <i class="fas fa-sort"></i></th>
								<th>Beschreibung (DE) <i class="fas fa-sort"></i></th>
								<th>Standardwert (DE) <i class="fas fa-sort"></i></th>
								<th title="Fett">B</th>
								<th title="Eingerückt">E</th>
								<th title="Versteckt">X</th>
								<th title="Unique">U</th>
								<th>UI-Seite</th>
								<th>UI</th>
								<th>Array</th>
							</tr>
						</thead>
						<tbody id="parameterTableBody">
							<!-- Parameter rows will be inserted here by JavaScript -->
							<tr><td colspan="13" style="text-align: center; color: #8899a6; padding: 15px;">Importiere eine XML-Datei, um Parameter anzuzeigen.</td></tr>
						</tbody>
					</table>
				</div>
			</section>

<aside class="right-panel">
				<h3>Parameterdetails</h3>
				<div class="properties-section">
					<label>Name:</label><input type="text" name="param_name" value="">
					<label>Typ:</label>
					<select name="param_type">
						<option>Length</option>
						<option>String</option>
						<option>Integer</option>
						<option>Boolean</option>
						<option>Angle</option>
						<option>RealNum</option>
						<option>Material</option>
						<option>LineType</option>
						<option>FillPattern</option>
						<option>PenColor</option>
						<option>Separator</option>
						<option>Title</option>
						<option>Dictionary</option>
						<option>Profile</option>
						<option>BuildingMaterial</option>
					</select>
					<label>Funktion:</label>
					<select name="param_function">
						<option>Geometrie</option>
						<option>Produktdaten</option>
						<option>Attribut</option>
						<option>GDL-Intern</option>
					</select>
					<label>Array:</label>
					<select name="param_array_type">
						<option value="None">Kein Array</option>
						<option value="1D">1-dimensionales Array</option>
						<option value="2D">2-dimensionales Array</option>
					</select>
					<label><input type="checkbox" name="flag_fix_name"> FIX Name</label>
					<label><input type="checkbox" name="flag_unique"> Unique</label>
					<label><input type="checkbox" name="flag_bold"> Fett</label>
					<label><input type="checkbox" name="flag_child"> Eingerückt</label>
					<label><input type="checkbox" name="flag_hidden"> Versteckt</label>
					<label>UI-Seite (0-99):</label><input type="number" name="param_ui_page" value="0" min="0" max="99">
					<label>UI-Code:</label><textarea name="param_ui_code" rows="3"></textarea>
				</div>
			
				<h3>Mehrsprachige Details</h3>
				<div class="properties-section language-tabs">
					<div class="tab-buttons">
						<button class="lang-tab active" data-lang="de">DE</button>
						<button class="lang-tab" data-lang="en">EN</button>
						<button class="lang-tab" data-lang="fr">FR</button>
						<button class="lang-tab" data-lang="es">ES</button>
						<button class="lang-tab" data-lang="it">IT</button>
					</div>
					<div class="lang-content active" data-lang="de">
						<label>Beschreibung (DE):</label><input type="text" name="desc_lang">
						<label>Standardwert (DE):</label><input type="text" name="default_val_lang">
						<label>VALUES (DE):</label><textarea name="values_list_lang" rows="2" placeholder="Werte komma-getrennt (z.B. 'Wert1,Wert2')"></textarea>
						<label>UI_TOOLTIP (DE):</label><textarea name="ui_tooltip_lang" rows="2"></textarea>
					</div>
					<div class="lang-content" data-lang="en">
						<label>Beschreibung (EN):</label><input type="text" name="desc_lang">
						<label>Standardwert (EN):</label><input type="text" name="default_val_lang">
						<label>VALUES (EN):</label><textarea name="values_list_lang" rows="2" placeholder="Comma-separated values (e.g., 'Value1,Value2')"></textarea>
						<label>UI_TOOLTIP (EN):</label><textarea name="ui_tooltip_lang" rows="2"></textarea>
					</div>
					<div class="lang-content" data-lang="fr">
						<label>Beschreibung (FR):</label><input type="text" name="desc_lang">
						<label>Standardwert (FR):</label><input type="text" name="default_val_lang">
						<label>VALUES (FR):</label><textarea name="values_list_lang" rows="2" placeholder="Valeurs séparées par des virgules"></textarea>
						<label>UI_TOOLTIP (FR):</label><textarea name="ui_tooltip_lang" rows="2"></textarea>
					</div>
					<div class="lang-content" data-lang="es">
						<label>Beschreibung (ES):</label><input type="text" name="desc_lang">
						<label>Standardwert (ES):</label><input type="text" name="default_val_lang">
						<label>VALUES (ES):</label><textarea name="values_list_lang" rows="2" placeholder="Valores separados por comas"></textarea>
						<label>UI_TOOLTIP (ES):</label><textarea name="ui_tooltip_lang" rows="2"></textarea>
					</div>
					<div class="lang-content" data-lang="it">
						<label>Beschreibung (IT):</label><input type="text" name="desc_lang">
						<label>Standardwert (IT):</label><input type="text" name="default_val_lang">
						<label>VALUES (IT):</label><textarea name="values_list_lang" rows="2" placeholder="Valori separati da virgole"></textarea>
						<label>UI_TOOLTIP (IT):</label><textarea name="ui_tooltip_lang" rows="2"></textarea>
					</div>
				</div>
			</aside>
		</main>

		<!-- FOOTER -->
		<footer class="app-footer">
			<span class="status-message" id="statusMessage">Status: Bereit.</span>
			<span class="grid-info">Zuletzt aktualisiert: Heute 15:30</span>
			<span class="zoom-info" id="rowCount">Zeilen: 0</span>
		</footer>
	</div>

<script>
		document.addEventListener('DOMContentLoaded', () => {
			const API_BASE_URL = 'http://localhost:8888/gdl-ui-studio/backend/public/api';
			
			// DOM Elements
			const projectSelector = document.getElementById('projectSelector');
			const objectSelector = document.getElementById('objectSelector');
			const newProjectBtn = document.getElementById('newProjectBtn');
			const newObjectBtn = document.getElementById('newObjectBtn');
			const refreshProjectsBtn = document.getElementById('refreshProjectsBtn');
			const refreshObjectsBtn = document.getElementById('refreshObjectsBtn');
			
			const importXmlButton = document.getElementById('importXmlButton');
			const xmlFileInput = document.getElementById('xmlFileInput');
			const parameterTableBody = document.getElementById('parameterTableBody');
			const statusMessage = document.getElementById('statusMessage');
			const rowCountSpan = document.getElementById('rowCount');
			const filterInput = document.getElementById('filter-param');
			
			// State
			let currentProjectId = localStorage.getItem('currentProjectId');
			let currentGdlObjectId = localStorage.getItem('currentGdlObjectId');
			let currentGdlObjectName = '';
			let currentProjectName = '';
			let allParameters = [];
			let selectedParameterIds = new Set();
			let currentEditingParam = null;
			let selectedRowParameterId = null;
			let typeColors = {};
		
			const GDL_TYPES = [
				'Length', 'String', 'Integer', 'Boolean', 'Angle', 'RealNum',
				'Material', 'LineType', 'FillPattern', 'PenColor',
				'Separator', 'Title', 'Dictionary', 'Profile', 'BuildingMaterial'
			];
		
			// ===== INITIALIZATION =====
			init();
		
			async function init() {
				setupEventListeners();
				await loadProjects();
				
				if (currentProjectId) {
					projectSelector.value = currentProjectId;
					await loadObjects(currentProjectId);
					
					if (currentGdlObjectId) {
						objectSelector.value = currentGdlObjectId;
						await loadParameters(currentGdlObjectId);
					}
				}
			}
		
			// ===== EVENT LISTENERS =====
			function setupEventListeners() {
				// Project selector
				projectSelector.addEventListener('change', async (e) => {
					const projectId = e.target.value;
					if (projectId) {
						currentProjectId = projectId;
						localStorage.setItem('gdl_current_project_id', projectId);
						await loadObjects(projectId);
						
						// Clear object selection
						currentGdlObjectId = null;
						localStorage.removeItem('gdl_current_object_id');
						objectSelector.value = '';
						clearParameterTable();
					} else {
						currentProjectId = null;
						localStorage.removeItem('gdl_current_project_id');
						objectSelector.innerHTML = '<option value="">-- Objekt wählen --</option>';
						objectSelector.disabled = true;
						clearParameterTable();
					}
				});
		
				// Object selector
				objectSelector.addEventListener('change', async (e) => {
					const objectId = e.target.value;
					if (objectId) {
						currentGdlObjectId = objectId;
						localStorage.setItem('gdl_current_object_id', objectId);
						await loadParameters(objectId);
					} else {
						currentGdlObjectId = null;
						localStorage.removeItem('gdl_current_object_id');
						clearParameterTable();
					}
				});
		
				// New project button
				newProjectBtn.addEventListener('click', async () => {
					const projectName = prompt('Neues Projekt erstellen\n\nProjektname eingeben:');
					if (projectName && projectName.trim()) {
						await createProject(projectName.trim());
					}
				});
		
				// New object button
				newObjectBtn.addEventListener('click', async () => {
					if (!currentProjectId) {
						alert('Bitte wählen Sie zuerst ein Projekt.');
						return;
					}
					const objectName = prompt('Neues GDL-Objekt erstellen\n\nObjektname eingeben (z.B. "Fenster_01.gsm"):');
					if (objectName && objectName.trim()) {
						await createGdlObject(objectName.trim());
					}
				});
		
				// Refresh buttons
				refreshProjectsBtn.addEventListener('click', () => loadProjects());
				refreshObjectsBtn.addEventListener('click', () => {
					if (currentProjectId) loadObjects(currentProjectId);
				});
		
				// Import XML
				importXmlButton.addEventListener('click', () => {
					if (!currentProjectId) {
						alert('Bitte wählen Sie zuerst ein Projekt.');
						return;
					}
					xmlFileInput.click();
				});
				xmlFileInput.addEventListener('change', handleXmlImport);
		
				// Header buttons
				document.getElementById('generateBtn')?.addEventListener('click', () => {
					if (currentGdlObjectId) {
						exportXml(currentGdlObjectId);
					} else {
						alert('Bitte wählen Sie zuerst ein GDL-Objekt.');
					}
				});
		
				document.getElementById('downloadBtn')?.addEventListener('click', () => {
					if (currentGdlObjectId) {
						exportXml(currentGdlObjectId);
					} else {
						alert('Bitte wählen Sie zuerst ein GDL-Objekt.');
					}
				});
		
				document.getElementById('saveBtn')?.addEventListener('click', () => {
					alert('Alle Änderungen werden automatisch gespeichert.');
				});
		
				// Left panel action buttons
				const actionButtons = document.querySelectorAll('.action-btn');
				actionButtons.forEach(btn => {
					const text = btn.textContent.trim();
					if (text === 'Parameter Export (XML)') {
						btn.addEventListener('click', () => {
							if (currentGdlObjectId) {
								exportXml(currentGdlObjectId);
							} else {
								alert('Bitte wählen Sie zuerst ein GDL-Objekt.');
							}
						});
					} else if (text === 'Neuen Parameter hinzufügen') {
						btn.addEventListener('click', showAddParameterDialog);
					} else if (text === 'Ausgewählte löschen') {
						btn.addEventListener('click', deleteSelectedParameters);
					}
				});
		
				// Filter
				if (filterInput) {
					filterInput.addEventListener('input', filterParameters);
				}
		
				// Language tabs
				setupLanguageTabs();
				
				// Right panel listeners
				setupRightPanelListeners();
			}
		
			function setupLanguageTabs() {
				const langTabs = document.querySelectorAll('.language-tabs .lang-tab');
				const langContents = document.querySelectorAll('.language-tabs .lang-content');
		
				langTabs.forEach(tab => {
					tab.addEventListener('click', () => {
						langTabs.forEach(t => t.classList.remove('active'));
						tab.classList.add('active');
		
						const targetLang = tab.dataset.lang;
						langContents.forEach(content => {
							content.classList.toggle('active', content.dataset.lang === targetLang);
						});
					});
				});
			}
		
			function setupRightPanelListeners() {
				const rightPanel = document.querySelector('.right-panel');
				
				rightPanel.querySelectorAll('input, select, textarea').forEach(element => {
					let saveTimeout;
					element.addEventListener('change', () => {
						clearTimeout(saveTimeout);
						saveTimeout = setTimeout(() => {
							if (currentEditingParam) {
								updateParameterFromRightPanel();
							}
						}, 500);
					});
				});
			}
		
			// ===== PROJECT MANAGEMENT =====
			async function loadProjects() {
				try {
					statusMessage.textContent = 'Status: Projekte werden geladen...';
					const response = await fetch(`${API_BASE_URL}/projects`);
					const result = await response.json();
		
					projectSelector.innerHTML = '<option value="">-- Projekt wählen --</option>';
		
					if (response.ok && result.projects) {
						result.projects.forEach(project => {
							const option = document.createElement('option');
							option.value = project.id;
							option.textContent = `${project.name} (${project.object_count || 0} Objekte)`;
							projectSelector.appendChild(option);
						});
						
						if (result.projects.length === 0) {
							statusMessage.textContent = 'Status: Keine Projekte vorhanden. Erstellen Sie ein neues Projekt.';
						} else {
							statusMessage.textContent = 'Status: Projekte geladen.';
						}
					} else {
						statusMessage.textContent = `Fehler beim Laden der Projekte: ${result.error || 'Unbekannter Fehler'}`;
					}
				} catch (error) {
					statusMessage.textContent = `Netzwerkfehler: ${error.message}`;
					console.error('Error loading projects:', error);
				}
			}
		
			async function createProject(projectName) {
				try {
					statusMessage.textContent = 'Status: Projekt wird erstellt...';
					
					const response = await fetch(`${API_BASE_URL}/projects`, {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ name: projectName })
					});
		
					const result = await response.json();
		
					if (response.ok) {
						statusMessage.textContent = `Status: Projekt "${projectName}" erstellt.`;
						await loadProjects();
						projectSelector.value = result.projectId;
						projectSelector.dispatchEvent(new Event('change'));
					} else if (response.status === 409) {
						const useExisting = confirm(`Projekt "${projectName}" existiert bereits.\n\nMöchten Sie dieses Projekt laden?`);
						if (useExisting && result.existingProjectId) {
							await loadProjects();
							projectSelector.value = result.existingProjectId;
							projectSelector.dispatchEvent(new Event('change'));
						}
					} else {
						statusMessage.textContent = `Fehler: ${result.error}`;
					}
				} catch (error) {
					statusMessage.textContent = `Netzwerkfehler: ${error.message}`;
				}
			}
		
			// ===== GDL OBJECT MANAGEMENT =====
			async function loadObjects(projectId) {
				try {
					statusMessage.textContent = 'Status: GDL-Objekte werden geladen...';
					const response = await fetch(`${API_BASE_URL}/projects/${projectId}/objects`);
					const result = await response.json();
		
					objectSelector.innerHTML = '<option value="">-- Objekt wählen --</option>';
					objectSelector.disabled = false;
		
					if (response.ok && result.gdl_objects) {
						result.gdl_objects.forEach(obj => {
							const option = document.createElement('option');
							option.value = obj.id;
							option.textContent = `${obj.name} (${obj.parameter_count || 0} Parameter)`;
							objectSelector.appendChild(option);
						});
						
						if (result.gdl_objects.length === 0) {
							statusMessage.textContent = 'Status: Keine GDL-Objekte vorhanden. Erstellen Sie ein neues Objekt.';
						} else {
							statusMessage.textContent = 'Status: GDL-Objekte geladen.';
						}
					} else {
						statusMessage.textContent = `Fehler beim Laden der Objekte: ${result.error || 'Unbekannter Fehler'}`;
					}
				} catch (error) {
					statusMessage.textContent = `Netzwerkfehler: ${error.message}`;
					console.error('Error loading objects:', error);
				}
			}
		
			async function createGdlObject(objectName) {
				try {
					statusMessage.textContent = 'Status: GDL-Objekt wird erstellt...';
					
					const response = await fetch(`${API_BASE_URL}/objects`, {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ 
							project_id: currentProjectId,
							name: objectName 
						})
					});
		
					const result = await response.json();
		
					if (response.ok) {
						statusMessage.textContent = `Status: GDL-Objekt "${objectName}" erstellt.`;
						await loadObjects(currentProjectId);
						objectSelector.value = result.objectId;
						objectSelector.dispatchEvent(new Event('change'));
					} else if (response.status === 409) {
						const useExisting = confirm(`GDL-Objekt "${objectName}" existiert bereits.\n\nMöchten Sie dieses Objekt laden?`);
						if (useExisting && result.existingObjectId) {
							await loadObjects(currentProjectId);
							objectSelector.value = result.existingObjectId;
							objectSelector.dispatchEvent(new Event('change'));
						}
					} else {
						statusMessage.textContent = `Fehler: ${result.error}`;
					}
				} catch (error) {
					statusMessage.textContent = `Netzwerkfehler: ${error.message}`;
				}
			}
		
			// ===== XML IMPORT =====
			async function handleXmlImport(event) {
				const file = event.target.files[0];
				if (!file) return;
		
				// Automatischer Objektname aus Dateinamen
				const objectName = file.name.replace('.xml', '').replace('_Param', '').replace('Parameters', '') + '.gsm';
		
				statusMessage.textContent = 'Status: XML-Datei wird gelesen...';
		
				const reader = new FileReader();
				reader.onload = async (e) => {
					const xmlContent = e.target.result;
		
					statusMessage.textContent = 'Status: Parameter werden importiert...';
		
					try {
						const response = await fetch(`${API_BASE_URL}/parameters/import`, {
							method: 'POST',
							headers: { 'Content-Type': 'application/json' },
							body: JSON.stringify({
								xml_content: xmlContent,
								project_id: currentProjectId,
								object_name: objectName,
							}),
						});
		
						const result = await response.json();
		
						if (response.ok) {
							statusMessage.textContent = `Status: ${result.message}`;
							await loadObjects(currentProjectId);
							objectSelector.value = result.gdlObjectId;
							objectSelector.dispatchEvent(new Event('change'));
						} else {
							statusMessage.textContent = `Fehler: ${result.error || 'Unbekannter Fehler'}`;
							console.error('Import failed:', result);
						}
					} catch (error) {
						statusMessage.textContent = `Netzwerkfehler: ${error.message}`;
						console.error('Network error:', error);
					}
					
					xmlFileInput.value = '';
				};
				reader.readAsText(file);
			}
		
			// ===== LOAD PARAMETERS =====
			async function loadParameters(objectId) {
				if (!objectId) {
					clearParameterTable();
					return;
				}
		
				statusMessage.textContent = 'Status: Parameter werden geladen...';
				
				try {
					const response = await fetch(`${API_BASE_URL}/objects/${objectId}/parameters`);
					const data = await response.json();
		
					if (response.ok) {
					currentGdlObjectName = data.object_name || '';
						allParameters = data.parameters || [];
						renderParameters();
						statusMessage.textContent = 'Status: Parameter erfolgreich geladen.';
					} else {
						statusMessage.textContent = `Fehler beim Laden: ${data.error || 'Unbekannter Fehler'}`;
						console.error('Failed to load parameters:', data);
					}
				} catch (error) {
					statusMessage.textContent = `Netzwerkfehler beim Laden: ${error.message}`;
					console.error('Network error:', error);
				}
			}
		
			function clearParameterTable() {
				parameterTableBody.innerHTML = '<tr><td colspan="13" style="text-align: center; color: #8899a6; padding: 15px;">Bitte wählen Sie ein GDL-Objekt aus.</td></tr>';
				rowCountSpan.textContent = 'Zeilen: 0';
			}
		
			// ===== RENDER PARAMETERS =====
			function renderParameters() {
				parameterTableBody.innerHTML = '';
				
				if (allParameters.length === 0) {
					parameterTableBody.innerHTML = '<tr><td colspan="13" style="text-align: center; color: #8899a6; padding: 15px;">Keine Parameter vorhanden. Importieren Sie eine XML-Datei oder erstellen Sie einen neuen Parameter.</td></tr>';
					rowCountSpan.textContent = 'Zeilen: 0';
					return;
				}
		
				allParameters.forEach((param, index) => {
					const row = createParameterRow(param, index);
					parameterTableBody.appendChild(row);
				});
		
				rowCountSpan.textContent = `Zeilen: ${allParameters.length}`;
				updateDeleteButtonState();
			}
		
			function createParameterRow(param, index) {
				const row = document.createElement('tr');
				row.dataset.parameterId = param.id;
				row.draggable = true;
		
				const deTranslation = param.translations.find(t => t.language_code === 'de');
				const descriptionDe = deTranslation ? deTranslation.description : '';
		
				let defaultValueDisplay = '';
				if (param.default_value_json) {
					try {
						const parsedValue = JSON.parse(param.default_value_json);
						if (typeof parsedValue === 'object' && parsedValue !== null) {
							defaultValueDisplay = Array.isArray(parsedValue) ? `[Array ${parsedValue.length}]` : `{Dict}`;
						} else {
							defaultValueDisplay = parsedValue;
						}
					} catch (e) {
						defaultValueDisplay = param.default_value_json;
					}
				}
		
				const typeSelectHtml = `
					<select class="param-type-select param-table-select" data-param-id="${param.id}">
						${GDL_TYPES.map(type => 
							`<option value="${type}" ${param.gdl_type === type ? 'selected' : ''}>${type}</option>`
						).join('')}
					</select>
				`;
		
				row.innerHTML = `
					<td><input type="checkbox" class="param-checkbox" data-param-id="${param.id}"></td>
					<td class="drag-handle"><i class="fas fa-grip-vertical"></i></td>
					<td>${typeSelectHtml}</td>
					<td class="editable" data-field="gdl_name">${param.gdl_name}</td>
					<td class="editable" data-field="description_de">${descriptionDe}</td>
					<td class="editable" data-field="default_value">${defaultValueDisplay}</td>
					<td><input type="checkbox" class="flag-checkbox" data-field="flag_bold" ${param.flag_bold ? 'checked' : ''}></td>
					<td><input type="checkbox" class="flag-checkbox" data-field="flag_child" ${param.flag_child ? 'checked' : ''}></td>
					<td><input type="checkbox" class="flag-checkbox" data-field="flag_hidden" ${param.flag_hidden ? 'checked' : ''}></td>
					<td><input type="checkbox" class="flag-checkbox" data-field="flag_unique" ${param.flag_unique ? 'checked' : ''}></td>
					<td class="editable" data-field="ui_page">${param.ui_page || 0}</td>
					<td><input type="checkbox" class="flag-checkbox" data-field="is_ui_element" ${param.is_ui_element ? 'checked' : ''}></td>
					<td>${param.array_type !== 'None' ? param.array_type : ''}</td>
				`;
		
				row.querySelector('.param-checkbox').addEventListener('change', handleCheckboxChange);
				row.querySelector('.param-type-select').addEventListener('change', (e) => handleTypeChange(param.id, e));
				row.querySelectorAll('.flag-checkbox').forEach(cb => cb.addEventListener('change', (e) => handleFlagChange(param.id, e)));
				row.querySelectorAll('.editable').forEach(cell => {
					cell.addEventListener('click', () => makeEditable(cell, param.id));
				});
				row.addEventListener('click', (e) => {
					if (!e.target.closest('input') && !e.target.closest('select') && !e.target.closest('.editable')) {
						selectParameter(param);
					}
				});
		
				row.addEventListener('dragstart', handleDragStart);
				row.addEventListener('dragover', handleDragOver);
				row.addEventListener('drop', handleDrop);
				row.addEventListener('dragend', handleDragEnd);
		
				return row;
			}
		
			// ===== REST OF THE FUNCTIONS (same as before) =====
			// Füge hier alle weiteren Funktionen ein:
			// - handleTypeChange
			// - makeEditable
			// - updateParameterField
			// - handleFlagChange
			// - selectParameter
			// - updateRightPanel
			// - updateParameterFromRightPanel
			// - showAddParameterDialog
			// - addParameter
			// - handleCheckboxChange
			// - updateDeleteButtonState
			// - deleteSelectedParameters
			// - Drag & Drop functions
			// - filterParameters
			// - exportXml
		
			async function handleTypeChange(parameterId, event) {
				const newType = event.target.value;
				try {
					const response = await fetch(`${API_BASE_URL}/parameters/${parameterId}`, {
						method: 'PUT',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ gdl_type: newType })
					});
					if (response.ok) {
						const param = allParameters.find(p => p.id === parameterId);
						param.gdl_type = newType;
						statusMessage.textContent = 'Status: Typ geändert.';
						if (currentEditingParam && currentEditingParam.id === parameterId) {
							document.querySelector('select[name="param_type"]').value = newType;
						}
					}
				} catch (error) {
					statusMessage.textContent = `Netzwerkfehler: ${error.message}`;
				}
			}
		

		// ===== TYPE CHANGE IN TABLE =====
		async function handleTypeChange(parameterId, event) {
			const newType = event.target.value;
	
			try {
				const response = await fetch(`${API_BASE_URL}/parameters/${parameterId}`, {
					method: 'PUT',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ gdl_type: newType })
				});
	
				if (response.ok) {
					const param = allParameters.find(p => p.id === parameterId);
					param.gdl_type = newType;
					statusMessage.textContent = 'Status: Typ geändert.';
					
					// Update right panel if this param is selected
					if (currentEditingParam && currentEditingParam.id === parameterId) {
						document.querySelector('select[name="param_type"]').value = newType;
					}
				} else {
					const result = await response.json();
					statusMessage.textContent = `Fehler: ${result.error}`;
					event.target.value = allParameters.find(p => p.id === parameterId).gdl_type; // Revert
				}
			} catch (error) {
				statusMessage.textContent = `Netzwerkfehler: ${error.message}`;
				event.target.value = allParameters.find(p => p.id === parameterId).gdl_type; // Revert
			}
		}
	
		// ===== INLINE EDITING =====
		function makeEditable(cell, parameterId) {
			if (cell.querySelector('input')) return;
	
			const originalValue = cell.textContent.trim();
			const field = cell.dataset.field;
			
			const input = document.createElement('input');
			input.type = 'text';
			input.value = originalValue;
			input.style.width = '100%';
			input.style.padding = '4px';
			input.style.border = '1px solid var(--accent-color)';
			input.style.backgroundColor = '#4c566a';
			input.style.color = 'var(--text-color)';
	
			cell.innerHTML = '';
			cell.appendChild(input);
			input.focus();
			input.select();
	
			const saveEdit = async () => {
				const newValue = input.value.trim();
				if (newValue !== originalValue) {
					await updateParameterField(parameterId, field, newValue);
				}
				cell.textContent = newValue || originalValue;
			};
	
			input.addEventListener('blur', saveEdit);
			input.addEventListener('keypress', (e) => {
				if (e.key === 'Enter') {
					input.blur();
				}
			});
		}
	
		async function updateParameterField(parameterId, field, value) {
			const updateData = {};
			
			if (field === 'description_de') {
				const param = allParameters.find(p => p.id === parameterId);
				const translations = param.translations.map(t => ({
					...t,
					description: t.language_code === 'de' ? value : t.description
				}));
				updateData.translations = translations;
			} else if (field === 'default_value') {
				updateData.default_value_json = value;
			} else {
				updateData[field] = value;
			}
	
			try {
				const response = await fetch(`${API_BASE_URL}/parameters/${parameterId}`, {
					method: 'PUT',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify(updateData)
				});
	
				if (response.ok) {
					const param = allParameters.find(p => p.id === parameterId);
					if (field === 'description_de') {
						const deTranslation = param.translations.find(t => t.language_code === 'de');
						if (deTranslation) deTranslation.description = value;
					} else if (field === 'default_value') {
						param.default_value_json = value;
					} else {
						param[field] = value;
					}
					statusMessage.textContent = 'Status: Änderung gespeichert.';
				} else {
					const result = await response.json();
					statusMessage.textContent = `Fehler beim Speichern: ${result.error}`;
				}
			} catch (error) {
				statusMessage.textContent = `Netzwerkfehler: ${error.message}`;
			}
		}
	
		async function handleFlagChange(parameterId, event) {
			const field = event.target.dataset.field;
			const value = event.target.checked;
	
			try {
				const response = await fetch(`${API_BASE_URL}/parameters/${parameterId}`, {
					method: 'PUT',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ [field]: value })
				});
	
				if (response.ok) {
					const param = allParameters.find(p => p.id === parameterId);
					param[field] = value;
					statusMessage.textContent = 'Status: Flag gespeichert.';
				}
			} catch (error) {
				statusMessage.textContent = `Netzwerkfehler: ${error.message}`;
			}
		}
	
		// ===== SELECTION & RIGHT PANEL =====
		function selectParameter(param) {
			document.querySelectorAll('#parameterTableBody tr').forEach(r => r.classList.remove('selected'));
			const row = document.querySelector(`tr[data-parameter-id="${param.id}"]`);
			if (row) row.classList.add('selected');
	
			currentEditingParam = param;
			selectedRowParameterId = param.id; // Für "nach dieser Zeile einfügen"
			updateRightPanel(param);
		}
	
		function updateRightPanel(param) {
			const rightPanel = document.querySelector('.right-panel');
			if (!rightPanel || !param) return;
	
			rightPanel.querySelector('input[name="param_name"]').value = param.gdl_name || '';
			rightPanel.querySelector('select[name="param_type"]').value = param.gdl_type || 'Length';
			rightPanel.querySelector('select[name="param_function"]').value = param.function_group || 'Geometrie';
			rightPanel.querySelector('select[name="param_array_type"]').value = param.array_type || 'None';
			rightPanel.querySelector('input[name="flag_fix_name"]').checked = param.is_fix_name;
			rightPanel.querySelector('input[name="flag_unique"]').checked = param.flag_unique;
			rightPanel.querySelector('input[name="flag_bold"]').checked = param.flag_bold;
			rightPanel.querySelector('input[name="flag_child"]').checked = param.flag_child;
			rightPanel.querySelector('input[name="flag_hidden"]').checked = param.flag_hidden;
			rightPanel.querySelector('input[name="param_ui_page"]').value = param.ui_page || 0;
			rightPanel.querySelector('textarea[name="param_ui_code"]').value = param.ui_code || '';
	
			// Update translations
			document.querySelectorAll('.lang-content').forEach(langContent => {
				const lang = langContent.dataset.lang;
				const translation = param.translations.find(t => t.language_code === lang);
				
				if (translation) {
					langContent.querySelector('input[name="desc_lang"]').value = translation.description || '';
					langContent.querySelector('textarea[name="values_list_lang"]').value = translation.values_list || '';
					langContent.querySelector('textarea[name="ui_tooltip_lang"]').value = translation.ui_tooltip || '';
				} else {
					langContent.querySelector('input[name="desc_lang"]').value = '';
					langContent.querySelector('textarea[name="values_list_lang"]').value = '';
					langContent.querySelector('textarea[name="ui_tooltip_lang"]').value = '';
				}
				
				langContent.querySelector('input[name="default_val_lang"]').value = param.default_value_json || '';
			});
		}
	
		async function updateParameterFromRightPanel() {
			if (!currentEditingParam) return;
	
			const rightPanel = document.querySelector('.right-panel');
			const activeLang = rightPanel.querySelector('.lang-tab.active').dataset.lang;
			const activeLangContent = rightPanel.querySelector(`.lang-content[data-lang="${activeLang}"]`);
	
			const updateData = {
				gdl_name: rightPanel.querySelector('input[name="param_name"]').value,
				gdl_type: rightPanel.querySelector('select[name="param_type"]').value,
				function_group: rightPanel.querySelector('select[name="param_function"]').value,
				array_type: rightPanel.querySelector('select[name="param_array_type"]').value,
				is_fix_name: rightPanel.querySelector('input[name="flag_fix_name"]').checked,
				flag_unique: rightPanel.querySelector('input[name="flag_unique"]').checked,
				flag_bold: rightPanel.querySelector('input[name="flag_bold"]').checked,
				flag_child: rightPanel.querySelector('input[name="flag_child"]').checked,
				flag_hidden: rightPanel.querySelector('input[name="flag_hidden"]').checked,
				ui_page: parseInt(rightPanel.querySelector('input[name="param_ui_page"]').value),
				ui_code: rightPanel.querySelector('textarea[name="param_ui_code"]').value,
				default_value_json: activeLangContent.querySelector('input[name="default_val_lang"]').value,
				translations: [{
					language_code: activeLang,
					description: activeLangContent.querySelector('input[name="desc_lang"]').value,
					values_list: activeLangContent.querySelector('textarea[name="values_list_lang"]').value,
					ui_tooltip: activeLangContent.querySelector('textarea[name="ui_tooltip_lang"]').value
				}]
			};
	
			try {
				const response = await fetch(`${API_BASE_URL}/parameters/${currentEditingParam.id}`, {
					method: 'PUT',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify(updateData)
				});
	
				if (response.ok) {
					Object.assign(currentEditingParam, updateData);
					await loadParameters(currentGdlObjectId);
					statusMessage.textContent = 'Status: Parameter aktualisiert.';
				}
			} catch (error) {
				statusMessage.textContent = `Fehler beim Speichern: ${error.message}`;
			}
		}
	
		// ===== ADD PARAMETER =====
		function showAddParameterDialog() {
			if (!currentGdlObjectId) {
				alert('Bitte wählen Sie zuerst ein GDL-Objekt.');
				return;
			}
	
			const paramName = prompt('Neuen Parameter erstellen\n\nBitte geben Sie den Parameternamen ein:');
			
			if (paramName && paramName.trim()) {
				addParameter(paramName.trim());
			}
		}
	
		async function addParameter(gdlName) {
			try {
				const requestBody = {
					gdl_object_id: currentGdlObjectId,
					gdl_name: gdlName,
					gdl_type: 'String',
					translations: [
						{ language_code: 'de', description: gdlName },
						{ language_code: 'en', description: gdlName }
					]
				};
	
				// Wenn eine Zeile markiert ist, nach dieser einfügen
				if (selectedRowParameterId) {
					requestBody.insert_after_param_id = selectedRowParameterId;
				}
	
				const response = await fetch(`${API_BASE_URL}/parameters/create`, {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify(requestBody)
				});
	
				const result = await response.json();
	
				if (response.ok) {
					statusMessage.textContent = `Status: Parameter "${gdlName}" erstellt.`;
					await loadParameters(currentGdlObjectId);
				} else {
					statusMessage.textContent = `Fehler: ${result.error}`;
				}
			} catch (error) {
				statusMessage.textContent = `Netzwerkfehler: ${error.message}`;
			}
		}
	
		// ===== DELETE PARAMETERS =====
		function handleCheckboxChange(event) {
			const parameterId = parseInt(event.target.dataset.paramId);
			
			if (event.target.checked) {
				selectedParameterIds.add(parameterId);
			} else {
				selectedParameterIds.delete(parameterId);
			}
			
			updateDeleteButtonState();
		}
	
		function updateDeleteButtonState() {
			const deleteBtn = document.querySelector('.action-btn.delete-param');
			
			if (selectedParameterIds.size > 0) {
				deleteBtn.classList.remove('disabled');
			} else {
				deleteBtn.classList.add('disabled');
			}
		}
	
		async function deleteSelectedParameters() {
			if (selectedParameterIds.size === 0) return;
	
			const confirmed = confirm(`Möchten Sie wirklich ${selectedParameterIds.size} Parameter löschen?`);
			if (!confirmed) return;
	
			try {
				const response = await fetch(`${API_BASE_URL}/parameters/bulk-delete`, {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ parameter_ids: Array.from(selectedParameterIds) })
				});
	
				const result = await response.json();
	
				if (response.ok) {
					statusMessage.textContent = `Status: ${result.deleted_count} Parameter gelöscht.`;
					selectedParameterIds.clear();
					await loadParameters(currentGdlObjectId);
				} else {
					statusMessage.textContent = `Fehler: ${result.error}`;
				}
			} catch (error) {
				statusMessage.textContent = `Netzwerkfehler: ${error.message}`;
			}
		}
	
		// ===== DRAG & DROP REORDERING =====
		let draggedRow = null;
	
		function handleDragStart(e) {
			draggedRow = this;
			this.style.opacity = '0.4';
			e.dataTransfer.effectAllowed = 'move';
		}
	
		function handleDragOver(e) {
			if (e.preventDefault) {
				e.preventDefault();
			}
			e.dataTransfer.dropEffect = 'move';
			
			const targetRow = e.target.closest('tr');
			if (targetRow && targetRow !== draggedRow && targetRow.dataset.parameterId) {
				const rect = targetRow.getBoundingClientRect();
				const midpoint = rect.top + rect.height / 2;
				
				if (e.clientY < midpoint) {
					targetRow.parentNode.insertBefore(draggedRow, targetRow);
				} else {
					targetRow.parentNode.insertBefore(draggedRow, targetRow.nextSibling);
				}
			}
			
			return false;
		}
	
		function handleDrop(e) {
			if (e.stopPropagation) {
				e.stopPropagation();
			}
			return false;
		}
	
		async function handleDragEnd(e) {
			this.style.opacity = '1';
			
			const rows = Array.from(parameterTableBody.querySelectorAll('tr'));
			const orderedIds = rows.map(row => parseInt(row.dataset.parameterId)).filter(id => !isNaN(id));
			
			if (orderedIds.length > 0) {
				await saveParameterOrder(orderedIds);
			}
		}
	
		async function saveParameterOrder(orderedIds) {
			try {
				const response = await fetch(`${API_BASE_URL}/parameters/reorder`, {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ ordered_ids: orderedIds })
				});
	
				if (response.ok) {
					statusMessage.textContent = 'Status: Reihenfolge gespeichert.';
					const newOrder = [];
					orderedIds.forEach(id => {
						const param = allParameters.find(p => p.id === id);
						if (param) newOrder.push(param);
					});
					allParameters = newOrder;
				}
			} catch (error) {
				statusMessage.textContent = `Fehler beim Speichern der Reihenfolge: ${error.message}`;
			}
		}
	
		// ===== FILTER =====
		function filterParameters() {
			const filterText = filterInput.value.toLowerCase();
			const rows = parameterTableBody.querySelectorAll('tr');
			
			let visibleCount = 0;
			rows.forEach(row => {
				if (row.dataset.parameterId) {
					const text = row.textContent.toLowerCase();
					const isVisible = text.includes(filterText);
					row.style.display = isVisible ? '' : 'none';
					if (isVisible) visibleCount++;
				}
			});
			
			rowCountSpan.textContent = `Zeilen: ${visibleCount} / ${allParameters.length}`;
		}
	
		// ===== EXPORT XML =====
		async function exportXml(objectId) {
			if (!objectId) {
				alert('Kein GDL-Objekt geladen.');
				return;
			}
	
			try {
				statusMessage.textContent = 'Status: XML wird generiert...';
				
				const response = await fetch(`${API_BASE_URL}/objects/${objectId}/parameters/export`);
				
				if (response.ok) {
					const blob = await response.blob();
					const url = window.URL.createObjectURL(blob);
					const a = document.createElement('a');
					a.href = url;
					a.download = `${currentGdlObjectName.replace('.gsm', '')}_parameters.xml`;
					document.body.appendChild(a);
					a.click();
					window.URL.revokeObjectURL(url);
					document.body.removeChild(a);
					
					statusMessage.textContent = 'Status: XML erfolgreich exportiert.';
				} else {
					statusMessage.textContent = 'Fehler beim XML-Export.';
				}
			} catch (error) {
				statusMessage.textContent = `Netzwerkfehler: ${error.message}`;
			}
		}
	});
	</script>


	
	<!-- Array Editor Modal -->
	<div class="modal" id="arrayEditorModal">
		<div class="modal-content" style="max-width: 900px;">
			<div class="modal-header">
				<h2 id="arrayEditorTitle">Array-Parameter Editor</h2>
			</div>
			
			<div class="form-group">
				<label>Parameter: <span id="arrayParamName"></span></label>
			</div>
			
			<div class="form-group">
				<label>Array-Typ:</label>
				<select id="arrayTypeSelect">
					<option value="None">None</option>
					<option value="1D">1D Array</option>
					<option value="2D">2D Array</option>
				</select>
			</div>
			
			<div class="form-group" id="arrayModeGroup">
				<label>Werte-Modus:</label>
				<div style="display: flex; gap: 20px; margin-top: 10px;">
					<label><input type="radio" name="arrayMode" value="manual" checked> Manuell eingeben</label>
					<label><input type="radio" name="arrayMode" value="same"> Alle gleich</label>
					<label><input type="radio" name="arrayMode" value="increment"> Hochzählend</label>
				</div>
				
				<div id="arrayModeOptions" style="margin-top: 10px; display: none;">
					<input type="text" id="arrayFillValue" placeholder="Wert für 'Alle gleich' oder Startwert für 'Hochzählend'" style="width: 100%;">
				</div>
			</div>
			
			<div id="array1DContainer" style="display: none;">
				<h3>1D Array <span id="array1DSize"></span></h3>
				<table class="array-table">
					<thead>
						<tr>
							<th>Index</th>
							<th>Wert</th>
							<th style="width: 50px;"></th>
						</tr>
					</thead>
					<tbody id="array1DBody"></tbody>
				</table>
				<button type="button" class="btn btn-secondary" onclick="addArray1DRow()">+ Zeile hinzufügen</button>
			</div>
			
			<div id="array2DContainer" style="display: none;">
				<h3>2D Array <span id="array2DSize"></span></h3>
				<div style="overflow-x: auto;">
					<table class="array-table" id="array2DTable">
						<thead id="array2DHead"></thead>
						<tbody id="array2DBody"></tbody>
					</table>
				</div>
				<div style="margin-top: 10px;">
					<button type="button" class="btn btn-secondary" onclick="addArray2DRow()">+ Zeile hinzufügen</button>
					<button type="button" class="btn btn-secondary" onclick="addArray2DCol()">+ Spalte hinzufügen</button>
				</div>
			</div>
			
			<div class="form-actions">
				<button type="button" class="btn btn-secondary" onclick="closeArrayEditor()">Abbrechen</button>
				<button type="button" class="btn btn-primary" onclick="saveArrayValues()">Speichern</button>
			</div>
		</div>
	</div>

</body>
	</html>

